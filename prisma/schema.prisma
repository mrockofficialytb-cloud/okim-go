generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  PICKED_UP
  RETURNED
  CANCELED
}

enum UserRole {
  USER
  ADMIN
}

enum DepositStatus {
  UNPAID
  PAID
  RETURNED
}

model User {
  id               String    @id @default(cuid())
  name             String?
  firstName        String?
  lastName         String?
  email            String    @unique
  phone            String?
  emailVerified    DateTime?
  image            String?
  passwordHash     String?
  role             UserRole  @default(USER)
  privacyConsentAt DateTime?
  termsConsentAt   DateTime?
  marketingConsent Boolean   @default(false)

  dateOfBirth         DateTime?
  addressStreet       String?
  addressCity         String?
  addressZip          String?
  idDocumentNumber    String?
  driverLicenseNumber String?
  driverLicenseExpiry DateTime?

  accounts               Account[]
  sessions               Session[]
  reservations           Reservation[]
  adminNotes             UserAdminNote[]
  passwordResetTokens    PasswordResetToken[]
  emailVerificationCodes EmailVerificationCode[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model CarModel {
  id        String       @id @default(cuid())
  slug      String       @unique
  brand     String
  model     String
  image     String?
  active    Boolean      @default(true)
  variants  CarVariant[]
  createdAt DateTime     @default(now())
}

model CarVariant {
  id               String  @id @default(cuid())
  carModelId       String
  name             String
  transmission     String
  fuel             String
  seats            Int
  pricePerDayShort Int
  pricePerDayLong  Int
  quantity         Int     @default(1)
  image            String?
  active           Boolean @default(true)

  carModel     CarModel        @relation(fields: [carModelId], references: [id])
  reservations Reservation[]
  blocked      BlockedPeriod[]

  createdAt DateTime @default(now())
}

model Reservation {
  id           String            @id @default(cuid())
  carVariantId String
  userId       String?
  dateFrom     DateTime
  dateTo       DateTime
  customerName String
  email        String
  phone        String
  totalPrice   Int
  status       ReservationStatus @default(PENDING)

  depositAmount Int?
  depositStatus DepositStatus?

  pickupTimePlanned String?
  returnTimePlanned String?

  pickupAt      DateTime?
  pickupMileage Int?
  pickupFuel    String?
  pickupNote    String?

  pickupOwnerSignature    String?
  pickupCustomerSignature String?
  pickupOwnerSignedAt     DateTime?
  pickupCustomerSignedAt  DateTime?

  returnAt      DateTime?
  returnMileage Int?
  returnFuel    String?
  returnNote    String?

  carVariant CarVariant @relation(fields: [carVariantId], references: [id])
  user       User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([userId])
}

model BlockedPeriod {
  id           String   @id @default(cuid())
  carVariantId String
  dateFrom     DateTime
  dateTo       DateTime
  reason       String?

  carVariant CarVariant @relation(fields: [carVariantId], references: [id])

  createdAt DateTime @default(now())
}

model UserAdminNote {
  id        String   @id @default(cuid())
  userId    String
  note      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model EmailVerificationCode {
  id        String    @id @default(cuid())
  userId    String
  email     String
  code      String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([email, code])
}